#!/bin/bash

TAGS="record"
CATEGORY_ID=7

while [[ $# -gt 0 ]]; do
  case $1 in
    --tags) TAGS="$2"; shift 2 ;;
    --category-id) CATEGORY_ID="$2"; shift 2 ;;
    *) filename=$(cygpath -u "$1" 2>/dev/null || echo "$1"); shift ;;
  esac
done

if [ -z "$filename" ]; then
  echo "Usage: $0 [--tags tags] [--category-id id] filename"
  exit 1
fi

if [ ! -f "$filename" ]; then
  echo "File not found: $filename"
  exit 1
fi

if ! [ -r "$filename" ]; then
  echo "File not readable: $filename"
  exit 1
fi

if ! file "$filename" | grep -q "text"; then
  echo "Not a text file: $filename"
  exit 1
fi

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

if ! bash "${SCRIPT_DIR}/refresh_chyrp_token" >/dev/null; then
  echo "Error: could not refresh Chyrp admin session"
  exit 1
fi

source ~/.bashrc.secret

if [ -z "$CHYRP_TOKEN" ] || [ -z "$CHYRP_HASH" ]; then
  echo "Error: CHYRP_TOKEN and CHYRP_HASH must be set"
  exit 1
fi

# Extract title: first line, strip leading "# "
POST_TITLE=$(head -n 1 "$filename" | sed 's/^# //')

if [ -z "$POST_TITLE" ]; then
  echo "Error: no title found in $filename"
  exit 1
fi

# Duplicate check
LOG_DIR=~/logs
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/$(basename "$0").log"

if [ -s "$LOG_FILE" ]; then
  LAST_TITLE=$(tail -n 1 "$LOG_FILE")
  if [ "$LAST_TITLE" = "$POST_TITLE" ]; then
    echo "Error: Duplicate title detected: $POST_TITLE"
    exit 1
  fi
fi

BOUNDARY='----WebKitFormBoundaryPubTechNote'
BLOG_URL='https://blog.shukebeta.com/admin/add_post/'
CREATED_AT=$(date +"%Y-%m-%d %H:%M:%S")
RESP_FILE=$(mktemp)
TMPBODY=$(mktemp)
TMPDATA=$(mktemp)

cleanup() {
  rm -f "$RESP_FILE" "$TMPBODY" "$TMPDATA"
}

trap cleanup EXIT

# Body: everything after the first line
# For long notes (>50 lines), insert <!-- more --> after line 25 for blog excerpt
tail -n +2 "$filename" > "$TMPBODY"
LINE_COUNT=$(wc -l < "$TMPBODY")

if [ "$LINE_COUNT" -gt 50 ]; then
  sed -i '25a\\n<!-- more -->\n' "$TMPBODY"
fi

# Build multipart body with CRLF line endings into a temp file to avoid
# shell variable mangling and cross-platform curl differences.
{
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"title\"\r\n\r\n"
  printf "%s\r\n" "$POST_TITLE"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"body\"\r\n\r\n"
  cat "$TMPBODY"
  printf "\r\n%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"status\"\r\n\r\npublic\r\n"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"slug\"\r\n\r\n\r\n"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"created_at\"\r\n\r\n"
  printf "%s\r\n" "$CREATED_AT"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"option[comment_status]\"\r\n\r\nopen\r\n"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"tags\"\r\n\r\n${TAGS}\r\n"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"option[category_id]\"\r\n\r\n${CATEGORY_ID}\r\n"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"feather\"\r\n\r\ntext\r\n"
  printf "%s\r\n" "--${BOUNDARY}"
  printf "Content-Disposition: form-data; name=\"hash\"\r\n\r\n${CHYRP_HASH}\r\n"
  printf "%s\r\n" "--${BOUNDARY}--"
} > "$TMPDATA"

HTTP_CODE=$(curl -s -o "$RESP_FILE" -w "%{http_code}" -X POST "${BLOG_URL}" \
  -H 'accept: text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8' \
  -H 'cache-control: max-age=0' \
  -H "Content-Type: multipart/form-data; boundary=${BOUNDARY}" \
  -b "ChyrpSession=$CHYRP_TOKEN" \
  -H 'origin: https://blog.shukebeta.com' \
  -H 'referer: https://blog.shukebeta.com/admin/' \
  -H 'sec-gpc: 1' \
  -H 'upgrade-insecure-requests: 1' \
  -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36" \
  --data-binary "@$TMPDATA")

if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "302" ]; then
  echo "$POST_TITLE" >> "$LOG_FILE"
  echo "OK: $POST_TITLE ($HTTP_CODE)"
else
  echo "FAIL: HTTP $HTTP_CODE"
  head -20 "$RESP_FILE"
  exit 1
fi
